# Demo deployment env template.
#
# Copy to `.env` next to this file, fill in the placeholders, then run
# `./infra/demo/deploy.sh` from the repo root.
#
#   cp infra/demo/.env.example .env
#   chmod 600 .env
#
# Generate the random secrets with:
#   openssl rand -base64 32 | tr -d '/+=' | head -c 32

# ── image pinning ──────────────────────────────────────────────────
SETA_VERSION=v0.0.1
SETA_IMAGE_SERVER=ghcr.io/<your-github-org>/seta-server:${SETA_VERSION}
SETA_IMAGE_WEB=ghcr.io/<your-github-org>/seta-web:${SETA_VERSION}

# ── public URLs ────────────────────────────────────────────────────
PUBLIC_URL=https://<your-demo-host>
CORS_ORIGINS=https://<your-demo-host>
SESSION_COOKIE_SAMESITE=lax
NODE_ENV=production
PORT=3000

# ── auth secret ────────────────────────────────────────────────────
BETTER_AUTH_SECRET=<openssl-rand-base64-48>

# ── postgres ───────────────────────────────────────────────────────
POSTGRES_USER=seta
POSTGRES_PASSWORD=<openssl-rand-base64-32>
POSTGRES_DB=seta
DATABASE_URL=postgres://seta:${POSTGRES_PASSWORD}@postgres:5432/seta

# ── object storage (S3-compatible) ─────────────────────────────────
# Point this at any S3 API: an external MinIO on the same host, an AWS
# S3 bucket, or any other S3 implementation. The signed presigned URL
# must be reachable from the browser, so use the public hostname.
S3_REGION=us-east-1
S3_ENDPOINT=https://<your-s3-host>
S3_BUCKET=seta-knowledge
S3_FORCE_PATH_STYLE=false
S3_ACCESS_KEY_ID=<your-s3-access-key>
S3_SECRET_ACCESS_KEY=<your-s3-secret>

# Hostname-only form of S3_ENDPOINT, used by compose.override.yml to add an
# extra_hosts entry so the server container reaches the S3 host without
# hairpinning through the public IP. Leave blank if S3 is on a real
# external service (e.g. AWS).
S3_PUBLIC_HOST=<your-s3-host>

# ── host port bindings ─────────────────────────────────────────────
# Loopback-only — the host reverse proxy forwards to these.
SETA_SERVER_HOST_PORT=13000
SETA_WEB_HOST_PORT=18080

# ── knowledge / antivirus ──────────────────────────────────────────
# Demo deployments drop the bundled ClamAV service. Set this back to
# `true` and add a `clamav` service if you need on-upload AV scanning.
KNOWLEDGE_AV_REQUIRED=false

# ── modules ────────────────────────────────────────────────────────
SETA_MODULES=*

# ── optional: Microsoft OIDC ───────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── retention / observability ──────────────────────────────────────
EVENTS_RETENTION_DAYS=14
OTEL_EXPORTER_OTLP_ENDPOINT=
